{
  "id": "http/reindex",
  "mode": "http",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": [
      "/reindex"
    ],
    "stdin": "{}",
    "cwd": "${CORPUS}"
  },
  "capture": [
    "stdout",
    "exit"
  ],
  "parse": "json",
  "tiers": {
    "stable": [],
    "ignore": []
  },
  "tolerances": {
    "score_abs": 0.05,
    "timed_max_ms": 60000
  },
  "expect_exit": 200
}
