{
  "id": "http/status",
  "mode": "http",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": ["/status"],
    "cwd": "${CORPUS}"
  },
  "capture": ["stdout", "exit"],
  "parse": "json",
  "tiers": {
    "stable": ["ready", "file_count", "indexing_active"],
    "ignore": [
      "pid", "start_time", "uptime_ms", "elapsed_ms", "request_id",
      "timestamp", "schema_version",
      "progress", "indexing_progress",
      "symbol_count"
    ]
  },
  "tolerances": {"score_abs": 0.05, "timed_max_ms": 60000},
  "expect_exit": 200
}
