{
  "id": "http/fileinfo",
  "mode": "http",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": [
      "/fileinfo"
    ],
    "stdin": "{\"file_id\":1}",
    "cwd": "${CORPUS}"
  },
  "capture": [
    "stdout",
    "exit"
  ],
  "parse": "json",
  "tiers": {
    "stable": [],
    "ignore": [
      "file_info.ID",
      "file_info.Path",
      "file_info.path",
      "file_info.file_id",
      "file_info.symbol_count",
      "file_info.LastModified",
      "file_info.Checksum",
      "file_info.FastHash",
      "file_info.ContentHash",
      "file_info.Blocks",
      "file_info.EnhancedSymbols",
      "file_info.Imports",
      "file_info.References",
      "file_info.ScopeHierarchy",
      "file_info.CharMask",
      "file_info.perf_data"
    ],
    "_rationale_ignore": "BASE_IGNORE_NON_DETERMINISM applies implicitly (pid/timestamp/elapsed_ms/version/jsonrpc envelope etc.); this list captures the descriptor-specific drift beyond the universal baseline."
  },
  "tolerances": {
    "score_abs": 0.05,
    "timed_max_ms": 60000
  },
  "expect_exit": 200
}
