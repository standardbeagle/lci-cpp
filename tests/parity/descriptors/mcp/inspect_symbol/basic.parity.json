{
  "id": "mcp/inspect_symbol/basic",
  "mode": "mcp",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": [
      "mcp"
    ],
    "stdin": "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"inspect_symbol\",\"arguments\":{\"name\":\"Add\"}}}",
    "cwd": "${CORPUS}"
  },
  "capture": [
    "stdout",
    "exit"
  ],
  "parse": "json",
  "tiers": {
    "stable": [
      "result.content[].type",
      "result.content[].text"
    ],
    "ignore": []
  },
  "tolerances": {
    "score_abs": 0.05,
    "timed_max_ms": 60000
  },
  "expect_exit": 0
}
