{
  "id": "cli/symbols/symbols",
  "mode": "cli",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {"args": ["symbols","--kind","function"], "cwd": "${CORPUS}"},
  "capture": ["stdout","exit"],
  "parse": "text",
  "tiers": {},
  "tolerances": {"score_abs": 0.0, "timed_max_ms": 60000},
  "expect_exit": 0
}
