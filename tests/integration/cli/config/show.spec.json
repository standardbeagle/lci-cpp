{
  "id": "cli/config/show",
  "golden": "goldens/cli/config/show.txt",
  "mode": "cli",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": [
      "config",
      "show"
    ],
    "cwd": "${CORPUS}"
  },
  "capture": [
    "stdout",
    "exit"
  ],
  "parse": "text",
  "tiers": {},
  "tolerances": {
    "score_abs": 0.0,
    "timed_max_ms": 60000
  },
  "expect_exit": 0,
  "text_normalize": {
    "replace": [
      {
        "pattern": "Max goroutines:\\s+\\d+",
        "with": "Max goroutines:     N"
      }
    ]
  }
}
