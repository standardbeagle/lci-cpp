{
  "id": "cli/debug/validate",
  "golden": "goldens/cli/debug/validate.txt",
  "mode": "cli",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": [
      "debug",
      "validate"
    ],
    "cwd": "${CORPUS}"
  },
  "capture": [
    "stdout",
    "exit"
  ],
  "parse": "text",
  "tiers": {},
  "tolerances": {
    "score_abs": 0.0,
    "timed_max_ms": 60000
  },
  "expect_exit": 0,
  "text_normalize": {
    "strip_emoji_prefix": true,
    "strip_lines": [
      "Incremental Mode:",
      "Building index...",
      "Linking symbols"
    ],
    "replace": [
      {
        "pattern": "^Root Path: \\.$",
        "with": "Root Path: ${CORPUS}"
      }
    ]
  }
}
