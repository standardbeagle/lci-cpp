{
  "id": "cli/version",
  "golden": "goldens/cli/version.txt",
  "mode": "cli",
  "corpus": "empty",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": [
      "--version"
    ],
    "cwd": "${CORPUS}"
  },
  "capture": [
    "stdout",
    "exit"
  ],
  "parse": "text",
  "tiers": {},
  "tolerances": {
    "score_abs": 0.0,
    "timed_max_ms": 60000
  },
  "expect_exit": 0,
  "text_normalize": {
    "replace": [
      {
        "pattern": "[0-9]+\\.[0-9]+\\.[0-9]+",
        "with": "VERSION"
      }
    ]
  }
}
