{
  "id": "http/browse-file",
  "golden": "goldens/http/browse-file.json",
  "mode": "http",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": ["/browse-file"],
    "stdin": "{\"file\":\"a.go\"}",
    "cwd": "${CORPUS}"
  },
  "capture": ["stdout", "exit"],
  "parse": "json",
  "_rationale_ignore": "object_id and file.file_id are sequential synthetic IDs assigned during indexing; integration runs are stable on path/line/name/type/refs but the ID integers depend on scanner-completion order which can drift slightly across runs.",
  "tiers": {
    "stable": [],
    "ignore": [
      "pid", "start_time", "version", "uptime_ms", "elapsed_ms",
      "request_id", "timestamp", "schema_version",
      "file.file_id",
      "symbols[].object_id"
    ]
  },
  "tolerances": {"score_abs": 0.05, "timed_max_ms": 60000},
  "expect_exit": 200
}
