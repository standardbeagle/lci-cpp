{
  "id": "http/git-analyze",
  "golden": "goldens/http/git-analyze.json",
  "mode": "http",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": ["/git-analyze"],
    "stdin": "{\"scope\":\"wip\"}",
    "cwd": "${CORPUS}"
  },
  "capture": ["stdout", "exit"],
  "parse": "json",
  "tiers": {
    "stable": [],
    "ignore": [
      "pid",
      "start_time",
      "version",
      "uptime_ms",
      "elapsed_ms",
      "request_id",
      "timestamp",
      "schema_version",
      "report.metadata.analysis_time_ms",
      "report.metadata.analyzed_at",
      "report.metrics_issues",
      "report.summary.risk_score",
      "report.summary.symbols_modified",
      "report.summary.top_recommendation",
      "report.summary.files_changed",
      "report.summary.metrics_issues_found",
      "report.summary.naming_issues_found",
      "report.summary.duplicates_found",
      "report.summary.symbols_added",
      "report.summary.symbols_deleted"
    ]
  },
  "tolerances": {"score_abs": 0.05, "timed_max_ms": 60000},
  "expect_exit": 200
}
