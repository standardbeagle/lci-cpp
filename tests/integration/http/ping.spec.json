{
  "id": "http/ping",
  "golden": "goldens/http/ping.json",
  "mode": "http",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": ["/ping"],
    "cwd": "${CORPUS}"
  },
  "capture": ["stdout", "exit"],
  "parse": "json",
  "tiers": {
    "stable": [],
    "ignore": [
      "pid", "start_time", "uptime_ms", "elapsed_ms", "request_id",
      "timestamp", "schema_version",
      "uptime_seconds",
      "build_id",
      "version"
    ]
  },
  "tolerances": {"score_abs": 0.05, "timed_max_ms": 60000},
  "expect_exit": 200
}
