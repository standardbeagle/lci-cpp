{
  "id": "mcp/info/basic",
  "golden": "goldens/mcp/info/basic.json",
  "mode": "mcp",
  "corpus": "multi-lang",
  "go_binary": "${LCI_GO}",
  "cpp_binary": "${LCI_CPP}",
  "invocation": {
    "args": ["mcp"],
    "stdin": "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"info\",\"arguments\":{}}}",
    "cwd": "${CORPUS}"
  },
  "capture": ["stdout", "exit"],
  "parse": "json",
  "tiers": {
    "stable": ["result.content[].type", "result.content[].text"],
    "ignore": ["id", "jsonrpc", "result.meta.elapsed_ms", "result.meta.server_pid"]
  },
  "tolerances": {"score_abs": 0.05, "timed_max_ms": 60000},
  "expect_exit": 0
}
