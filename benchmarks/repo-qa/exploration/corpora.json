        "argv": [
          "{python}",
          "{forge}",
          "check-imports",
          "--language",
          "typescript",
          "--exclude",
          "(^|/)(node_modules|__tests__)/|^packages/next/src/(compiled|bundles)/|^(test|tests|turbopack|crates|rspack|apps|\\.github|bench|docs|errors|scripts|examples)/|^packages/(?!next/src/)",
          "--allow-unresolved",
          "^\\.\\./build/polyfills/polyfill-module$|^\\./routes\\.js$|^\\./missing-module$|^next/dist/compiled/|^next/dist/esm/|^next/dist/server/capsize-font-metrics\\.json$",
