      "validation": {
        "comment": [
          "The import check is only an oracle if it is SILENT on the pristine tree.",
          "--exclude drops areas it cannot honestly model: vendored/build-generated",
          "shims (compiled/, bundles/), non-JS source (crates, turbopack), and test",
          "trees full of deliberately-broken fixtures.",
          "--allow-unresolved names the specifiers that legitimately do not resolve",
          "from source: polyfill-module and routes.js are emitted by the build, and",
