// Repo-QA benchmark configuration.
// Compares baseline opencode vs opencode + LCI MCP across models, repos, and
// question difficulties. Parsed by scripts/benchlib.py (flat KDL subset:
// node name, quoted string args, key=value props, one level of braces).

defaults {
    opencode-bin "opencode"
    lci-bin "/home/beagle/work/core/lci-cpp/build/src/lci"
    corpus-root "/home/beagle/work/core/lci-cpp/real_projects"
    judge-model "github-copilot/claude-sonnet-4.6"
    timeout-seconds 600
    concurrency 3
}

// size: small <30k LOC, medium 30-100k, large >100k
// complexity: low = single-purpose library, medium = multi-module framework,
// high = many subsystems / plugin architecture
repos {
    repo "chi"        path="go/chi"            language="go"         size="small"  complexity="low"    files=74   loc=10369
    repo "sinatra"    path="ruby/sinatra"      language="ruby"       size="small"  complexity="low"    files=147  loc=23891
    repo "guzzle"     path="php/guzzle"        language="php"        size="small"  complexity="low"    files=85   loc=20226
    repo "serilog"    path="csharp/serilog"    language="csharp"     size="small"  complexity="medium" files=216  loc=24754
    repo "gson"       path="java/gson"         language="java"       size="medium" complexity="medium" files=262  loc=55578
    repo "ripgrep"    path="rust/ripgrep"      language="rust"       size="medium" complexity="medium" files=101  loc=52361
    repo "zls"        path="zig/zls"           language="zig"        size="medium" complexity="medium" files=103  loc=58323
    repo "fastapi"    path="python/fastapi"    language="python"     size="large"  complexity="medium" files=1119 loc=107536
    repo "trpc"       path="typescript/trpc"   language="typescript" size="large"  complexity="high"   files=964  loc=117884
    repo "okhttp"     path="kotlin/okhttp"     language="kotlin"     size="large"  complexity="high"   files=596  loc=133346
    repo "pocketbase" path="go/pocketbase"     language="go"         size="large"  complexity="high"   files=448  loc=148554
}

// Verified working 2026-07-04 (PONG probe). Copilot models bill $0 marginal
// (subscription); openrouter models bill per token.
models {
    model "haiku45"    id="github-copilot/claude-haiku-4.5"     tier="cheap"
    model "gpt5mini"   id="openrouter/openai/gpt-5-mini"        tier="cheap"
    model "gemini25f"  id="openrouter/google/gemini-2.5-flash"  tier="cheap"
    model "sonnet46"   id="github-copilot/claude-sonnet-4.6"    tier="mid"
    model "qwen3coder" id="openrouter/qwen/qwen3-coder"         tier="mid"
    model "gpt41"      id="github-copilot/gpt-4.1"              tier="mid"
}

// Cost ladder: run tier 0 first to tune LCI + harness, then grow.
tiers {
    tier "0" repos="chi,sinatra"                       models="haiku45,gpt5mini"                       difficulties="easy,medium,hard" reps=1
    tier "1" repos="chi,sinatra"                       models="haiku45,gpt5mini,gemini25f,qwen3coder"  difficulties="easy,medium,hard" reps=2
    tier "2" repos="chi,sinatra,guzzle,ripgrep"        models="haiku45,gpt5mini,gemini25f,qwen3coder,sonnet46" difficulties="easy,medium,hard" reps=2
    tier "3" repos="chi,sinatra,guzzle,ripgrep,fastapi,trpc,pocketbase" models="haiku45,gpt5mini,gemini25f,qwen3coder,sonnet46,gpt41" difficulties="easy,medium,hard" reps=3
}
