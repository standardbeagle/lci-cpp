// Repo-QA benchmark configuration.
// Compares baseline opencode vs opencode + LCI MCP across models, repos, and
// question difficulties. Parsed by scripts/benchlib.py (flat KDL subset:
// node name, quoted string args, key=value props, one level of braces).

defaults {
    opencode-bin "opencode"
    lci-bin "/home/beagle/work/core/lci-cpp/build/src/lci"
    corpus-root "/home/beagle/work/core/lci-cpp/real_projects"
    // Judge history: copilot sonnet-5 rejects sustained use; sonnet-4.6 was
    // solid for 700+ judgments then began mass-timing-out alongside all
    // copilot completions (plan throttle); big-pickle answers tiny probes
    // fast but blows the 240s budget on real-length grading prompts
    // (reasoning-model overthink). deepseek-v4-flash-free: 14s on a
    // realistic prompt, clean JSON, $0 on the opencode Go plan.
    // deepseek-v4-flash-free judged 100 results then hit its per-model zen
    // quota; north-mini-code misgrades; nemotron-3-ultra-free is fast (10s)
    // and sane. Caveat: nemotron is also a tier-3 candidate — treat its
    // scores on its own runs with self-preference caution (facts metric is
    // judge-independent).
    judge-model "opencode/nemotron-3-ultra-free"
    timeout-seconds 600
    concurrency 3
}

// size: small <30k LOC, medium 30-100k, large >100k.
// minefield: measured architectural treachery, not LOC — composite of
// call-graph chokepoint concentration, max cyclomatic complexity, cycles,
// layer violations, coupling/cohesion, modularity, and impurity, computed
// by LCI itself (scripts/profile_repos.py -> repo-profiles.json). LCI's
// purpose is identifying and navigating exactly these minefields, so the
// benchmark's difficulty axis is the minefield index: low <22, mid 22-30,
// high >30.
repos {
    repo "chi"        path="go/chi"            language="go"         size="small"  minefield=29.9 minefield-tier="mid"  files=74   loc=10369
    repo "sinatra"    path="ruby/sinatra"      language="ruby"       size="small"  minefield=17.5 minefield-tier="low"  files=147  loc=23891
    repo "guzzle"     path="php/guzzle"        language="php"        size="small"  minefield=15.6 minefield-tier="low"  files=85   loc=20226
    repo "serilog"    path="csharp/serilog"    language="csharp"     size="small"  minefield=24.6 minefield-tier="mid"  files=216  loc=24754
    repo "gson"       path="java/gson"         language="java"       size="medium" minefield=23.0 minefield-tier="mid"  files=262  loc=55578
    repo "ripgrep"    path="rust/ripgrep"      language="rust"       size="medium" minefield=20.4 minefield-tier="low"  files=101  loc=52361
    repo "zls"        path="zig/zls"           language="zig"        size="medium" minefield=38.6 minefield-tier="high" files=103  loc=58323
    repo "fastapi"    path="python/fastapi"    language="python"     size="large"  minefield=23.3 minefield-tier="mid"  files=1119 loc=107536
    repo "trpc"       path="typescript/trpc"   language="typescript" size="large"  minefield=20.9 minefield-tier="low"  files=964  loc=117884
    repo "okhttp"     path="kotlin/okhttp"     language="kotlin"     size="large"  minefield=34.3 minefield-tier="high" files=596  loc=133346
    repo "pocketbase" path="go/pocketbase"     language="go"         size="large"  minefield=36.9 minefield-tier="high" files=448  loc=148554
}

// Verified working 2026-07-04 (PONG probe). Copilot models bill $0 marginal
// (subscription); openrouter models bill per token. Latest-generation rows
// added after a web sweep of July-2026 releases (Sonnet 5, GPT-5.5, GLM-5.2,
// Kimi K2.7-code, Qwen 3.7 Max, DeepSeek V4 Pro, Gemini 3.5 Flash).
models {
    // $0 models: opencode zen free tier (probed PONG 2026-07-04) and zai
    // (works but 429-throttled — run with concurrency 1).
    model "dsv4free"   id="opencode/deepseek-v4-flash-free"       tier="free"
    model "nemotron"   id="opencode/nemotron-3-ultra-free"        tier="free"
    model "northmini"  id="opencode/north-mini-code-free"         tier="free"
    model "mimo"       id="opencode/mimo-v2.5-free"               tier="free"
    model "bigpickle"  id="opencode/big-pickle"                   tier="free"
    model "glm47flash" id="zai/glm-4.7-flash"                     tier="free"
    // opencode Go plan namespace (opencode-go/*) + zhipuai coding plan +
    // kimi-for-coding — all probed alive 2026-07-05 evening. These are the
    // user-preferred accounts.
    model "godsv4pro"  id="opencode-go/deepseek-v4-pro"           tier="mid"
    model "goglm52"    id="opencode-go/glm-5.2"                   tier="mid"
    model "gokimi27"   id="opencode-go/kimi-k2.7-code"            tier="mid"
    model "gominimax3" id="opencode-go/minimax-m3"                tier="mid"
    model "goqwen37"   id="opencode-go/qwen3.7-max"               tier="frontier"
    model "zhipuglm52" id="zhipuai-coding-plan/glm-5.2"           tier="mid"
    model "kimik2p7"   id="kimi-for-coding/k2p7"                  tier="mid"
    model "haiku45"    id="github-copilot/claude-haiku-4.5"       tier="cheap"
    model "gpt5mini"   id="openrouter/openai/gpt-5-mini"          tier="cheap"
    model "gemini25f"  id="openrouter/google/gemini-2.5-flash"    tier="cheap"
    model "gemini35f"  id="openrouter/google/gemini-3.5-flash"    tier="cheap"
    model "sonnet46"   id="github-copilot/claude-sonnet-4.6"      tier="mid"
    model "qwen3coder" id="openrouter/qwen/qwen3-coder"           tier="mid"
    model "gpt41"      id="github-copilot/gpt-4.1"                tier="mid"
    model "deepseekv4" id="openrouter/deepseek/deepseek-v4-pro"   tier="mid"
    model "kimi27"     id="openrouter/moonshotai/kimi-k2.7-code"  tier="mid"
    model "glm52"      id="openrouter/z-ai/glm-5.2"               tier="mid"
    model "qwen37max"  id="openrouter/qwen/qwen3.7-max"           tier="frontier"
    model "sonnet5"    id="github-copilot/claude-sonnet-5"        tier="frontier"
    model "gpt55"      id="github-copilot/gpt-5.5"                tier="frontier"
    model "fable5"     id="github-copilot/claude-fable-5"         tier="frontier"
}

// Cost ladder: run tier 0 first to tune LCI + harness, then grow.
// difficulties can also include "micro" (tool-oriented single-call prompts).
tiers {
    tier "0" repos="chi,sinatra"                       models="haiku45,gpt5mini"                       difficulties="easy,medium,hard" reps=1
    tier "1" repos="chi,sinatra"                       models="haiku45,gpt5mini,gemini25f,qwen3coder"  difficulties="easy,medium,hard" reps=2
    tier "2" repos="chi,sinatra,guzzle,ripgrep"        models="haiku45,gpt5mini,gemini35f,qwen3coder,deepseekv4,kimi27,glm52" difficulties="easy,medium,hard" reps=2
    // tier 3 targets the high-minefield repos — where LCI's graph navigation
    // should matter most (zls 38.6, pocketbase 36.9, okhttp 34.3).
    tier "3" repos="chi,guzzle,zls,okhttp,pocketbase" models="haiku45,gpt5mini,gemini35f,deepseekv4,glm52,sonnet5,gpt55" difficulties="easy,medium,hard" reps=3
}
